# ========================================
# PostgreSQL + R2 Backup Configuration
# ========================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# ----------------------------------------
# PostgreSQL Credentials
# ----------------------------------------
PG_USER=anythingllm
PG_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
PG_DB=anythingllm
PG_PORT=5432

# ----------------------------------------
# Domain (used by Caddy for auto-SSL on HTTP services)
# ----------------------------------------
# A record in Cloudflare DNS → droplet IP (grey cloud, DNS only)
# PostgreSQL uses self-signed SSL on port 5432 (encrypted, no domain needed)
# Caddy handles Let's Encrypt SSL on port 443 for Mem0 / future HTTP services
PG_DOMAIN=db.yourdomain.com

# ----------------------------------------
# Cloudflare R2 Backup Storage
# ----------------------------------------
# Find these at: https://dash.cloudflare.com > R2 > Manage R2 API Tokens

R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=pg-backups

# ----------------------------------------
# Backup Retention
# ----------------------------------------
# Backups older than this many days are automatically deleted
RETENTION_DAYS=7
