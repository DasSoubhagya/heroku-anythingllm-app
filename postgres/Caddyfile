# Caddy reverse proxy -- auto SSL via Let's Encrypt
# Caddy stays idle until you add HTTP services

# When you deploy Mem0 later, uncomment and set your domain:
# mem0.yourdomain.com {
#     reverse_proxy mem0:8080
# }

# Health check endpoint (works on droplet IP, no domain needed)
:80 {
    respond /health "OK" 200
}
