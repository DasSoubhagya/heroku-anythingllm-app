# ========================================
# AnythingLLM Environment Configuration
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!

# ----------------------------------------
# Server Configuration
# ----------------------------------------
ANYTHINGLLM_PORT=3001
STORAGE_DIR=/app/server/storage

# Server auth token (generated on first boot, or set manually)
# AUTH_TOKEN=

# JWT secret for session management (auto-generated if not set)
# JWT_SECRET=

# ----------------------------------------
# LLM Provider API Keys (Active Providers)
# ----------------------------------------

# OpenRouter - access hundreds of models through one API
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-PASTE_YOUR_OPENROUTER_KEY_HERE
OPENROUTER_MODEL_PREF=openai/gpt-4o

# DeepInfra - fast inference for open-source models
# Get your key at: https://deepinfra.com/dash/api_keys
# DeepInfra uses the OpenAI-compatible generic endpoint
GENERIC_OPEN_AI_BASE_PATH=https://api.deepinfra.com/v1/openai
GENERIC_OPEN_AI_KEY=PASTE_YOUR_DEEPINFRA_KEY_HERE
GENERIC_OPEN_AI_MODEL_PREF=meta-llama/Meta-Llama-3.1-70B-Instruct
GENERIC_OPEN_AI_MAX_TOKENS=4096

# ----------------------------------------
# Embedding Provider API Keys
# ----------------------------------------

# OpenAI Embeddings (uses OPEN_AI_KEY above)
# EMBEDDING_ENGINE=openai
# EMBEDDING_MODEL_PREF=text-embedding-3-small

# Local Embeddings (built-in, no key needed)
# EMBEDDING_ENGINE=native

# ----------------------------------------
# Vector Database Configuration
# ----------------------------------------

# LanceDB (default, built-in, no config needed)
# VECTOR_DB=lancedb

# Chroma
# VECTOR_DB=chroma
# CHROMA_ENDPOINT=http://localhost:8000

# Pinecone
# VECTOR_DB=pinecone
# PINECONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PINECONE_INDEX=your-index-name

# QDrant
# VECTOR_DB=qdrant
# QDRANT_ENDPOINT=http://localhost:6333

# Weaviate
# VECTOR_DB=weaviate
# WEAVIATE_ENDPOINT=http://localhost:8080

# Milvus
# VECTOR_DB=milvus
# MILVUS_ADDRESS=http://localhost:19530

# ----------------------------------------
# Transcription Provider
# ----------------------------------------

# OpenAI Whisper (uses OPEN_AI_KEY above)
# WHISPER_PROVIDER=openai

# Local Whisper (built-in)
# WHISPER_PROVIDER=local

# ----------------------------------------
# Other Settings
# ----------------------------------------

# Disable telemetry
# DISABLE_TELEMETRY=true

# Password protection (optional, set a password to require login)
# PASSWORD_PROTECT=true
# SINGLE_USER_PASSWORD=your-secure-password

# Multi-user mode
# MULTI_USER_MODE=true
