# AnythingLLM runtime config
ANYTHINGLLM_PORT=3001
STORAGE_DIR=/app/server/storage

# Security (single-password login gate)
AUTH_TOKEN=CHANGE_ME_STRONG_PASSWORD
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
MULTI_USER_MODE=false

# LLM provider (DeepInfra via OpenAI-compatible endpoint)
GENERIC_OPEN_AI_BASE_PATH=https://api.deepinfra.com/v1/openai
GENERIC_OPEN_AI_KEY=PASTE_YOUR_DEEPINFRA_KEY
GENERIC_OPEN_AI_MODEL_PREF=MiniMaxAI/MiniMax-M2.5
GENERIC_OPEN_AI_MAX_TOKENS=4096

# Optional OpenRouter fallback
OPENROUTER_API_KEY=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_MODEL_PREF=openai/gpt-4o

# Optional
DISABLE_TELEMETRY=true
